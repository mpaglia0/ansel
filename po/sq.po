msgstr "metoda e përputhjes së kanaleve gjelbër"

#: ../src/iop/demosaic.c:2370
msgid "demosaicing is only used for color raw images"
msgstr "dematricimi përdoret vetëm për imazhet bruto me ngjyrë"

