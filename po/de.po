#: ../src/libs/export.c:1272 ../src/libs/print_settings.c:2281
#: ../src/libs/print_settings.c:2606
msgid "perceptual"
msgstr "Wahrnehmung"

#: ../src/libs/export.c:1273 ../src/libs/print_settings.c:2282
#: ../src/libs/print_settings.c:2607
msgid "relative colorimetric"
msgstr "relativ farbmetrisch"

#: ../src/libs/export.c:1274 ../src/libs/print_settings.c:2283
#: ../src/libs/print_settings.c:2608
msgctxt "rendering intent"
msgid "saturation"
msgstr "Sättigung"

#: ../src/libs/export.c:1275 ../src/libs/print_settings.c:2284
#: ../src/libs/print_settings.c:2609
msgid "absolute colorimetric"
msgstr "absolut farbmetrisch"

#: ../src/libs/export.c:1278
#, c-format
msgid ""
"• perceptual: smoothly moves out-of-gamut colors into gamut,preserving "
"gradations, but distorts in-gamut colors in the process. note that "
"perceptual is often a proprietary LUT that depends on the destination "
"space.\n"
"\n"
"• relative colorimetric: keeps luminance while reducing as little as "
"possible saturation until colors fit in gamut.\n"
"\n"
"• saturation: designed to present eye-catching business graphics by "
"preserving the saturation. (not suited for photography).\n"
"\n"
"• absolute colorimetric: adapt white point of the image to the white point "
"of the destination medium and do nothing else. mainly used when proofing "
"colors. (not suited for photography)."
msgstr ""
"• Wahrnehmungsabhängig: verschiebt Farben außerhalb des Gamuts sanft in den "
"Gamut, wobei die Abstufungen erhalten bleiben, aber die Farben im Gamut "
"werden dabei verzerrt. Beachten Sie, dass es sich bei der "
"wahrnehmungsabhängigen Methode oft um eine proprietäre LUT handelt, die vom "
"Zielraum abhängt.\n"
"\n"
"• Relativ farbmetrisch: Behält die Luminanz bei und reduziert die Sättigung "
"so weit wie möglich, bis die Farben in den Gamut passen.\n"
"\n"
"• Sättigung: Entwickelt, um auffällige Geschäftsgrafiken zu präsentieren, "
"indem die Sättigung beibehalten wird. (Nicht für die Fotografie geeignet).\n"
"\n"
"- absolut farbmetrisch: passt den Weißpunkt des Bildes an den Weißpunkt des "
"Zielmediums an und tut nichts anderes. Wird hauptsächlich beim Andrucken von "
"Farben verwendet. (Nicht für die Fotografie geeignet)."

