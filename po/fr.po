"output ΔE: \tavg. %.2f; \tmax. %.2f\n"
"\n"
"<b>Profile data</b>\n"
"illuminant:  \t%.0f K \t%s\n"
"matrix in adaptation space:\n"
"<tt>%+.4f \t%+.4f \t%+.4f\n"
"%+.4f \t%+.4f \t%+.4f\n"
"%+.4f \t%+.4f \t%+.4f</tt>\n"
"\n"
"<b>Normalization values</b>\n"
"exposure compensation: \t%+.2f EV\n"
"black offset: \t%+.4f"
