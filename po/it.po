msgid ""
"type a date in the form: YYYY:MM:DD[ hh:mm:ss[.sss]] if you want to override "
"the current date/time used when expanding variables:\n"
"$(YEAR), $(MONTH), $(DAY), $(HOUR), $(MINUTE), $(SECONDS), $(MSEC).\n"
"let the field empty otherwise"
